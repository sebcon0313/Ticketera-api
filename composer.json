{
    "name": "sistema/tickets-api",
    "description": "API Laravel para gestión de entradas",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "barryvdh/laravel-dompdf": "^2.0",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "predis/predis": "^2.1",
        "tymon/jwt-auth": "^2.3"
    },
    
    "autoload": {
